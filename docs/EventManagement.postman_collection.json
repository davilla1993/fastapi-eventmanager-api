            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Jazz Festival Paris 2025 — Édition Prestige\",\n  \"price\": \"55.00\",\n  \"status\": \"published\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/events/{{event_id}}",
