{
  "info": {
    "_postman_id": "event-management-api-collection",
    "name": "Event Management API",
    "description": "Collection complète pour l'API de gestion d'événements culturels.\n\n**Démarrage rapide :**\n1. Définir `base_url` dans les variables de collection\n2. Exécuter `Auth / Register` pour créer un compte\n3. Exécuter `Auth / Login` — le token JWT est sauvegardé automatiquement dans `{{token}}`\n4. Toutes les routes protégées utilisent `{{token}}` automatiquement",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "description": "URL de base de l'API. Remplacer par https://events-api.gfolly.com en production."
    },
    {
      "key": "token",
      "value": "",
      "description": "Token JWT — rempli automatiquement après un Login réussi."
    },
    {
      "key": "venue_id",
      "value": "",
      "description": "public_id d'une salle — à remplir après création."
    },
    {
      "key": "organizer_id",
      "value": "",
      "description": "public_id d'un organisateur — à remplir après création."
    },
    {
      "key": "category_id",
      "value": "",
      "description": "public_id d'une catégorie — à remplir après création."
    },
    {
      "key": "event_id",
      "value": "",
      "description": "public_id d'un événement — à remplir après création."
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Vérifie que le serveur est en ligne."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"Carlo Admin\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Crée un nouveau compte utilisateur (rôle USER par défaut)."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token JWT sauvegardé dans {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authentifie l'utilisateur et retourne un token JWT.\n\nLe token est **automatiquement sauvegardé** dans la variable `{{token}}` de la collection."
          }
        },
        {
          "name": "Me (profil connecté)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Retourne le profil de l'utilisateur actuellement connecté."
          }
        }
      ]
    },
    {
      "name": "Categories",
      "description": "Gestion des catégories thématiques. Création et modification réservées aux ADMIN.",
      "item": [
        {
          "name": "Créer une catégorie",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.public_id) {",
                  "    pm.collectionVariables.set('category_id', json.public_id);",
                  "    console.log('category_id sauvegardé : ' + json.public_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jazz\",\n  \"slug\": \"jazz\",\n  \"description\": \"Concerts et événements de jazz.\",\n  \"color\": \"#F59E0B\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories"]
            },
            "description": "Crée une catégorie. **Rôle requis : ADMIN**\n\nLe `public_id` est sauvegardé automatiquement dans `{{category_id}}`."
          }
        },
        {
          "name": "Lister les catégories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/categories?page=1&size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Obtenir une catégorie",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories", "{{category_id}}"]
            }
          }
        },
        {
          "name": "Modifier une catégorie",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jazz & Blues\",\n  \"color\": \"#D97706\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories", "{{category_id}}"]
            },
            "description": "Met à jour partiellement une catégorie. **Rôle requis : ADMIN**"
          }
        },
        {
          "name": "Supprimer une catégorie",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories", "{{category_id}}"]
            },
            "description": "Supprime une catégorie. Retourne 204 No Content."
          }
        }
      ]
    },
