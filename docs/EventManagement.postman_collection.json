    {
      "name": "Events",
      "description": "Gestion des événements culturels polymorphes : Concert, Théâtre, Conférence.",
      "item": [
        {
          "name": "Créer un Concert",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.public_id) {",
                  "    pm.collectionVariables.set('event_id', json.public_id);",
                  "    console.log('event_id sauvegardé : ' + json.public_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"concert\",\n  \"title\": \"Jazz Festival Paris 2025\",\n  \"slug\": \"jazz-festival-paris-2025\",\n  \"description\": \"Le plus grand festival de jazz parisien.\",\n  \"status\": \"published\",\n  \"start_at\": \"2025-07-14T20:00:00+02:00\",\n  \"end_at\": \"2025-07-14T23:30:00+02:00\",\n  \"venue_public_id\": \"{{venue_id}}\",\n  \"organizer_public_id\": \"{{organizer_id}}\",\n  \"category_public_id\": \"{{category_id}}\",\n  \"city\": \"Paris\",\n  \"price\": \"45.00\",\n  \"capacity\": 500,\n  \"image_url\": \"https://example.com/jazz.jpg\",\n  \"tags\": \"jazz,bebop,improvisation\",\n  \"artist\": \"Ibrahim Maalouf\",\n  \"genre\": \"Jazz contemporain\"\n}",
              "options": { "raw": { "language": "json" } }
